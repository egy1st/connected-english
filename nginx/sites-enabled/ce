server {
    listen 80;
    server_name connectedenglish.net;
    location ~ /.well-known {
        root /home/html;
    }
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    # listen on port 443 (https)
    listen 443 ssl;
    server_name _;

    # location of the self-signed SSL certificate
    ssl_certificate /etc/letsencrypt/live/connectedenglish.net/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/connectedenglish.net/privkey.pem;

    # write access and error logs to /var/log
    #access_log /var/log/ce_access.log;
    #error_log /var/log/ce_error.log;

    location / {
        # forward application requests to the gunicorn server
        proxy_pass http://localhost:8000;
        proxy_redirect off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location /static {
        # handle static files directly, without forwarding to the application
        alias /home/html/app/static;
        expires 30d;
    }

    location /pwabuilder-sw.js {
        # handle static files directly, without forwarding to the application
        alias /home/html/pwabuilder-sw.js;
        expires 30d;
    }

    location /_manifest.json {
        # handle static files directly, without forwarding to the application
        alias /home/html/_manifest.json;
        expires 30d;
    }

    location /scripts {
        # handle static files directly, without forwarding to the application
        alias /home/html/scripts;
        expires 30d;
    }

}
